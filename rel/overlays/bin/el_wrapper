#!/bin/bash
SOURCE="$0"
while [ -L "$SOURCE" ]; do
  DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
RELEASE_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

INSTALLED_VERSION=$(awk '{print $2}' "$RELEASE_ROOT/releases/start_erl.data" 2>/dev/null)
DAEMON_VERSION=$(cat ~/.el/daemon_version 2>/dev/null)

if [ -n "$DAEMON_VERSION" ] && [ -n "$INSTALLED_VERSION" ] && [ "$DAEMON_VERSION" != "$INSTALLED_VERSION" ]; then
  "$RELEASE_ROOT/bin/el" stop 2>/dev/null || true
  rm -f ~/.el/daemon_node ~/.el/daemon_version
  sleep 1
fi

case "$1" in
  start|daemon|stop|restart|pid|remote)
    exec "$RELEASE_ROOT/bin/el" "$@"
    ;;
  *)
    args=""
    for arg in "$@"; do
      escaped=$(printf '%s' "$arg" | sed 's/"/\\"/g')
      if [ -z "$args" ]; then
        args="\"$escaped\""
      else
        args="$args, \"$escaped\""
      fi
    done
    exec "$RELEASE_ROOT/bin/el" eval "El.CLI.dispatch([$args])"
    ;;
esac
