#!/bin/bash
SOURCE="$0"
while [ -L "$SOURCE" ]; do
  DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
RELEASE_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

case "$1" in
  start|daemon|stop|restart|pid|remote)
    exec "$RELEASE_ROOT/bin/el" "$@"
    ;;
  --version|-v|"")
    args=""
    for arg in "$@"; do
      escaped=$(printf '%s' "$arg" | sed 's/"/\\"/g')
      if [ -z "$args" ]; then
        args="\"$escaped\""
      else
        args="$args, \"$escaped\""
      fi
    done
    exec "$RELEASE_ROOT/bin/el" eval "El.CLI.dispatch([$args])"
    ;;
  *)
    args=""
    for arg in "$@"; do
      escaped=$(printf '%s' "$arg" | sed 's/"/\\"/g')
      if [ -z "$args" ]; then
        args="\"$escaped\""
      else
        args="$args, \"$escaped\""
      fi
    done

    "$RELEASE_ROOT/bin/el" rpc "El.CLI.dispatch([$args])" 2>/dev/null
    if [ $? -ne 0 ]; then
      "$RELEASE_ROOT/bin/el" daemon >/dev/null 2>&1 &
      n=0
      while [ $n -lt 10 ]; do
        "$RELEASE_ROOT/bin/el" rpc "El.CLI.dispatch([$args])" 2>/dev/null && exit 0
        n=$((n + 1))
      done
      echo "Failed to connect to daemon" >&2
      exit 1
    fi
    ;;
esac
